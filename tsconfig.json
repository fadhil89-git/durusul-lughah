{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "verbatimModuleSyntax": false
  },
  "include": ["src", "scripts", "*.mjs"],
  "exclude": ["dist", "node_modules"]
}
