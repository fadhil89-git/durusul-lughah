---
import "../../styles/global.css";
import DictionaryApp from "../../components/DictionaryApp.tsx";
import { entries, chapters, report } from "../../data/dictionary.ts";
console.log(`[kamus] ${report.entryCount} entri dimuat — ${report.perBuku.map((b) => `${b.buku}: ${b.entries}`).join(", ")}`);
---
<!doctype html>
<html lang="ms">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Kamus Buku Bahasa Arab Madinah dengan carian Arab, Melayu dan Inggeris serta nota nahu dan saraf." />
    <title>Kamus Buku Bahasa Arab Madinah | Tuwailib</title>
  </head>
  <body class="min-h-screen bg-paper">
    <script is:inline>
      // Normalize legacy kamus chapter URLs before the React island hydrates.
      (() => {
        const params = new URLSearchParams(window.location.search);
        const rawBab = params.get("bab") || "";
        if (params.has("buku") || !rawBab.includes("|")) return;
        const match = rawBab.match(/Buku\s*(\d+)\|(\d+)/i);
        if (!match) return;
        params.delete("bab");
        params.set("buku", match[1]);
        params.set("bab", match[2]);
        window.history.replaceState(null, "", `?${params.toString()}`);
      })();
    </script>
    <DictionaryApp client:load entries={entries} chapters={chapters} entryCount={report.entryCount} />
  </body>
</html>
