---
import "../../styles/global.css";
import DictionaryApp from "../../components/DictionaryApp.tsx";
import { entries, chapters, report } from "../../data/dictionary.ts";
console.log(`[kamus] ${report.entryCount} entri dimuat — ${report.perBuku.map((b) => `${b.buku}: ${b.entries}`).join(", ")}`);
---
<!doctype html>
<html lang="ms">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Kamus Buku Bahasa Arab Madinah dengan carian Arab, Melayu dan Inggeris serta nota nahu dan saraf." />
    <title>Kamus Buku Bahasa Arab Madinah | Tuwailib</title>
  </head>
  <body class="min-h-screen bg-paper">
    <DictionaryApp client:only="react" entries={entries} chapters={chapters} entryCount={report.entryCount}>
      <div slot="fallback" class="mx-auto w-full max-w-3xl px-4 py-10 text-sm text-muted">Memuat Kamus Buku Bahasa Arab Madinah...</div>
    </DictionaryApp>
  </body>
</html>
