---
import "../styles/global.css";
---
<!doctype html>
<html lang="ms">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Tuwailib ialah ruang belajar Durusul Lughah dengan syarah bab demi bab dan kamus carian Arab, Melayu dan Inggeris." />
    <title>Tuwailib</title>
  </head>
  <body class="min-h-screen bg-paper text-ink">
    <main class="mx-auto flex min-h-screen w-full max-w-3xl flex-col justify-center px-4 py-12">
      <div class="mb-10">
        <p class="arabic text-2xl text-accent" dir="rtl">طُوَيْلِب</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-normal text-ink sm:text-5xl">Tuwailib</h1>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted">
          Belajar Durusul Lughah al-‘Arabiyyah secara tersusun, dengan syarah ringkas dan kamus yang cepat dicari.
        </p>
      </div>

      <div class="grid gap-3 sm:grid-cols-2">
        <a href="/durusul-lughah" class="group rounded-2xl border border-line bg-panel p-5 shadow-sm transition hover:border-accent hover:bg-accent-soft">
          <span class="block text-sm font-semibold uppercase tracking-[0.08em] text-muted">Belajar</span>
          <span class="mt-3 block text-2xl font-semibold text-ink group-hover:text-accent">Syarah Kitab Durusul Lughah</span>
          <span class="mt-3 block text-sm leading-relaxed text-muted">Masuk ke senarai buku dan pilih bab yang mahu dibaca.</span>
        </a>

        <a href="/kamus" class="group rounded-2xl border border-line bg-panel p-5 shadow-sm transition hover:border-accent hover:bg-accent-soft">
          <span class="block text-sm font-semibold uppercase tracking-[0.08em] text-muted">Cari</span>
          <span class="mt-3 block text-2xl font-semibold text-ink group-hover:text-accent">Kamus Durusul Lughah</span>
          <span class="mt-3 block text-sm leading-relaxed text-muted">Cari kalimah Arab, maksud Melayu, Inggeris, jamak dan nota.</span>
        </a>
      </div>
    </main>
  </body>
</html>
