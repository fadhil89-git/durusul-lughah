---
import "../styles/global.css";
---
<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Tuwailib untuk belajar Buku Bahasa Arab Madinah, kamus dan mutun." />
    <title>طويلب</title>
  </head>
  <body class="min-h-screen bg-paper text-ink">
    <main class="mx-auto flex min-h-screen w-full max-w-3xl flex-col justify-center px-4 py-12">
      <div class="mb-8 flex flex-wrap items-center justify-between gap-3">
        <p class="arabic text-2xl text-accent" data-brand>طُوَيْلِب</p>
        <div class="flex flex-wrap gap-2" role="group" aria-label="Pilih bahasa">
          <button type="button" class="home-lang-btn is-active" data-home-lang="ar">العربية</button>
          <button type="button" class="home-lang-btn" data-home-lang="ms">Bahasa Melayu</button>
          <button type="button" class="home-lang-btn" data-home-lang="en">English</button>
        </div>
      </div>

      <section data-lang-panel="ar" class="mb-10 text-right">
        <h1 class="arabic mt-3 text-5xl font-semibold tracking-normal text-ink sm:text-6xl">طويلب</h1>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">
          تعلَّم كتاب دروس اللغة العربية لغير الناطقين بها بطريقة مرتبة، مع شرح الدروس ومعجم سريع للبحث.
        </p>
      </section>

      <section data-lang-panel="ms" class="mb-10 hidden text-left">
        <h1 class="mt-3 text-5xl font-semibold tracking-normal text-ink sm:text-6xl">Tuwailib</h1>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">
          Belajar Buku Bahasa Arab Madinah dengan syarah yang tersusun, kamus pantas dan mutun asas.
        </p>
      </section>

      <section data-lang-panel="en" class="mb-10 hidden text-left">
        <h1 class="mt-3 text-5xl font-semibold tracking-normal text-ink sm:text-6xl">Tuwailib</h1>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">
          Learn the Madinah Arabic Book with structured notes, a quick dictionary and selected mutun.
        </p>
      </section>

      <div class="grid gap-3 sm:grid-cols-3">
        <a href="/durusul-lughah" class="group rounded-2xl border border-line bg-panel p-5 shadow-sm transition hover:border-accent hover:bg-accent-soft">
          <span class="block text-sm font-semibold uppercase tracking-[0.08em] text-muted" data-i18n ar="التعلُّم" ms="Belajar" en="Learn">التعلُّم</span>
          <span class="arabic mt-3 block text-3xl font-semibold text-ink group-hover:text-accent" data-i18n ar="شرح كتاب دروس اللغة العربية لغير الناطقين بها" ms="Syarah Buku Bahasa Arab Madinah" en="Madinah Arabic Book Commentary">شرح كتاب دروس اللغة العربية لغير الناطقين بها</span>
          <span class="mt-3 block text-sm leading-relaxed text-muted" data-i18n ar="ادخل إلى قائمة الكتب، ثم اختر الدرس الذي تريد قراءته." ms="Pilih buku, kemudian terus lompat ke pelajaran yang mahu dibaca." en="Choose a book, then jump straight to the lesson you want.">ادخل إلى قائمة الكتب، ثم اختر الدرس الذي تريد قراءته.</span>
        </a>

        <a href="/kamus" class="group rounded-2xl border border-line bg-panel p-5 shadow-sm transition hover:border-accent hover:bg-accent-soft">
          <span class="block text-sm font-semibold uppercase tracking-[0.08em] text-muted" data-i18n ar="البحث" ms="Carian" en="Search">البحث</span>
          <span class="arabic mt-3 block text-3xl font-semibold text-ink group-hover:text-accent" data-i18n ar="معجم كتاب دروس اللغة العربية لغير الناطقين بها" ms="Kamus Buku Bahasa Arab Madinah" en="Madinah Arabic Book Dictionary">معجم كتاب دروس اللغة العربية لغير الناطقين بها</span>
          <span class="mt-3 block text-sm leading-relaxed text-muted" data-i18n ar="ابحث عن الكلمات العربية ومعانيها والجموع والملاحظات." ms="Cari kalimah Arab, maksud, jamak dan nota nahu atau saraf." en="Search Arabic words, meanings, plurals and grammar notes.">ابحث عن الكلمات العربية ومعانيها والجموع والملاحظات.</span>
        </a>

        <a href="/mutoon" class="group rounded-2xl border border-line bg-panel p-5 shadow-sm transition hover:border-accent hover:bg-accent-soft">
          <span class="block text-sm font-semibold uppercase tracking-[0.08em] text-muted" data-i18n ar="المتون" ms="Mutun" en="Mutun">المتون</span>
          <span class="arabic mt-3 block text-3xl font-semibold text-ink group-hover:text-accent" data-i18n ar="متون العلم" ms="Mutun" en="Mutun Texts">متون العلم</span>
          <span class="mt-3 block text-sm leading-relaxed text-muted" data-i18n ar="اقرأ المتون مع الترجمة والمفردات والشرح المختصر." ms="Baca matan dengan terjemahan, mufradat dan syarah ringkas." en="Read classical texts with translation, vocabulary and short notes.">اقرأ المتون مع الترجمة والمفردات والشرح المختصر.</span>
        </a>
      </div>
    </main>
    <script>
      const buttons = document.querySelectorAll("[data-home-lang]");
      const panels = document.querySelectorAll("[data-lang-panel]");
      const textNodes = document.querySelectorAll("[data-i18n]");

      function setHomeLanguage(lang) {
        document.documentElement.lang = lang;
        document.documentElement.dir = lang === "ar" ? "rtl" : "ltr";
        panels.forEach((panel) => panel.classList.toggle("hidden", panel.getAttribute("data-lang-panel") !== lang));
        buttons.forEach((button) => button.classList.toggle("is-active", button.getAttribute("data-home-lang") === lang));
        textNodes.forEach((node) => {
          const value = node.getAttribute(lang);
          if (value) node.textContent = value;
        });
        localStorage.setItem("tuwailib-home-lang", lang);
      }

      buttons.forEach((button) => {
        button.addEventListener("click", () => setHomeLanguage(button.getAttribute("data-home-lang") || "ar"));
      });
      setHomeLanguage(localStorage.getItem("tuwailib-home-lang") || "ar");
    </script>
  </body>
</html>
