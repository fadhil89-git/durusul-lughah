---
import "../../styles/global.css";
import LessonSearch from "../../components/LessonSearch.tsx";
import { lessonBooks } from "../../data/lessons.ts";
---
<!doctype html>
<html lang="ms">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Syarah Buku Bahasa Arab Madinah mengikut buku dan pelajaran." />
    <title>Syarah Buku Bahasa Arab Madinah | Tuwailib</title>
  </head>
  <body class="min-h-screen bg-paper text-ink">
    <header class="border-b border-line bg-panel">
      <div class="mx-auto flex w-full max-w-4xl items-center justify-between gap-4 px-4 py-5">
        <a href="/" class="text-lg font-semibold text-ink hover:text-accent">Tuwailib</a>
        <div class="flex items-center gap-2">
          <a href="/" class="rounded-full border border-line bg-paper px-4 py-2 text-sm font-semibold text-accent hover:bg-accent-soft">Home</a>
          <a href="/kamus" class="rounded-full border border-line bg-paper px-4 py-2 text-sm font-semibold text-accent hover:bg-accent-soft">Kamus</a>
        </div>
      </div>
    </header>

    <main class="mx-auto w-full max-w-4xl px-4 py-8">
      <div class="mb-8">
        <p class="arabic text-2xl text-accent" dir="rtl">دروس اللغة العربية لغير الناطقين بها</p>
        <h1 class="mt-2 text-3xl font-semibold text-ink sm:text-4xl">Syarah Buku Bahasa Arab Madinah</h1>
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted">
          Pilih buku dan terus lompat ke bab yang mahu dibaca. Setiap bab disusun dengan ringkasan, penerangan, contoh dan kesalahan biasa.
        </p>
      </div>

      <div class="space-y-6">
        <LessonSearch client:load />

        {lessonBooks.map((book) => (
          <details class="durusul-book-accordion" open>
            <summary>
              <span>
                <span class="durusul-book-kicker">{book.book}</span>
                <span class="durusul-book-title">{book.title}</span>
              </span>
              <span class="durusul-book-count">{book.chapters.length} bab</span>
            </summary>
            <div class="durusul-chapter-grid">
              {book.chapters.map((chapter) => (
                <div class="durusul-chapter-item" data-lesson-item data-read-key={`durusul:${chapter.bookNumber}:${chapter.chapter}`}>
                  <button
                    type="button"
                    class="durusul-read-check"
                    data-read-toggle
                    aria-label={`Tanda sudah baca ${chapter.book} Bab ${chapter.chapter}`}
                    aria-pressed="false"
                  >
                    ✓
                  </button>
                  <a href={`/durusul-lughah/buku-${chapter.bookNumber}/bab-${chapter.chapter}`} class="durusul-chapter-link">
                    <span class="durusul-chapter-number">Bab {chapter.chapter}</span>
                    <span class="durusul-chapter-title">
                      <span class="arabic" dir="rtl">{chapter.titleArabic}</span>
                      {chapter.titleMalay && <span>{chapter.titleMalay}</span>}
                    </span>
                  </a>
                </div>
              ))}
            </div>
          </details>
        ))}

      </div>
    </main>
    <script>
      const readStorageKey = "tuwailib:durusul-read";

      function readProgress() {
        try {
          return new Set(JSON.parse(localStorage.getItem(readStorageKey) || "[]"));
        } catch {
          return new Set();
        }
      }

      function writeProgress(progress) {
        localStorage.setItem(readStorageKey, JSON.stringify(Array.from(progress)));
      }

      const progress = readProgress();

      function applyReadState(item) {
        const key = item.dataset.readKey;
        const isRead = key ? progress.has(key) : false;
        item.classList.toggle("is-read", isRead);
        item.querySelector("[data-read-toggle]")?.setAttribute("aria-pressed", String(isRead));
      }

      document.querySelectorAll("[data-lesson-item]").forEach((item) => {
        applyReadState(item);
        item.querySelector("[data-read-toggle]")?.addEventListener("click", (event) => {
          event.preventDefault();
          event.stopPropagation();
          const key = item.dataset.readKey;
          if (!key) return;
          if (progress.has(key)) progress.delete(key);
          else progress.add(key);
          writeProgress(progress);
          applyReadState(item);
        });
      });
    </script>
  </body>
</html>
