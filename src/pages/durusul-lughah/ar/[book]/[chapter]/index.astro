---
import "../../../../../styles/global.css";
import LessonArticleNav from "../../../../../components/LessonArticleNav.tsx";
import { arabicLessons, hasArabicLesson } from "../../../../../data/lessonLocales.ts";
import { findLessonChapter, getAdjacentLesson, lessonChapters } from "../../../../../data/lessons.ts";

export function getStaticPaths() {
  return arabicLessons.map((lesson) => ({
    params: {
      book: `buku-${lesson.bookNumber}`,
      chapter: `bab-${lesson.chapter}`,
    },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const sourceChapter = findLessonChapter(`buku-${lesson.bookNumber}`, `bab-${lesson.chapter}`);
const previous = sourceChapter ? getAdjacentLesson(sourceChapter, -1) : undefined;
const next = sourceChapter ? getAdjacentLesson(sourceChapter, 1) : undefined;
const localizedPath = (bookNumber: number, chapter: number) =>
  hasArabicLesson(bookNumber, chapter)
    ? `/durusul-lughah/ar/buku-${bookNumber}/bab-${chapter}`
    : `/durusul-lughah/buku-${bookNumber}/bab-${chapter}`;
const chapterJumpItems = lessonChapters.map((item) => ({
  book: item.book,
  bookNumber: item.bookNumber,
  chapter: item.chapter,
  title: item.titleArabic || item.titleMalay,
  url: localizedPath(item.bookNumber, item.chapter),
}));
const dictionaryChapterUrl = `/kamus?buku=${lesson.bookNumber}&bab=${lesson.chapter}`;
---
<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`شرح عربي: كتاب ${lesson.bookNumber}، باب ${lesson.chapter}`} />
    <title>كتاب {lesson.bookNumber} باب {lesson.chapter} | Tuwailib</title>
  </head>
  <body id="top" class="min-h-screen bg-paper text-ink">
    <header class="border-b border-line bg-panel">
      <div class="mx-auto flex w-full max-w-4xl items-center justify-between gap-4 px-4 py-4">
        <a href="/" class="text-lg font-semibold text-ink hover:text-accent">Tuwailib</a>
        <div class="flex items-center gap-2">
          <a href="/" class="rounded-full border border-line bg-paper px-3 py-2 text-sm font-semibold text-accent hover:bg-accent-soft">الرئيسية</a>
          <a href="/durusul-lughah" class="rounded-full border border-line bg-paper px-3 py-2 text-sm font-semibold text-accent hover:bg-accent-soft">كل الدروس</a>
          <a href="/kamus" class="rounded-full border border-line bg-paper px-3 py-2 text-sm font-semibold text-accent hover:bg-accent-soft">المعجم</a>
        </div>
      </div>
    </header>

    <LessonArticleNav
      client:load
      chapters={chapterJumpItems}
      currentBook={lesson.bookNumber}
      currentChapter={lesson.chapter}
      language="ar"
    />

    <main class="mx-auto w-full max-w-4xl px-4 py-8">
      <nav class="mb-6 flex flex-wrap items-center justify-between gap-3 text-sm" dir="ltr">
        {previous ? <a href={localizedPath(previous.bookNumber, previous.chapter)} class="rounded-full border border-line bg-panel px-4 py-2 font-semibold text-accent hover:bg-accent-soft">← Previous</a> : <span></span>}
        {next ? <a href={localizedPath(next.bookNumber, next.chapter)} class="rounded-full border border-line bg-panel px-4 py-2 font-semibold text-accent hover:bg-accent-soft">Next →</a> : <span></span>}
      </nav>

      <article class="rounded-2xl border border-line bg-panel p-5 shadow-sm sm:p-8">
        <div class="mb-6 flex flex-wrap items-center justify-between gap-3" dir="ltr">
          <div class="flex flex-wrap items-center gap-2">
            <a href={`/durusul-lughah/buku-${lesson.bookNumber}/bab-${lesson.chapter}`} class="rounded-full border border-line bg-paper px-3 py-1.5 text-sm font-semibold text-accent hover:bg-accent-soft">BM</a>
            <span class="rounded-full border border-line bg-paper px-3 py-1.5 text-sm font-semibold text-muted">English</span>
            <span class="rounded-full border border-accent bg-accent px-3 py-1.5 text-sm font-semibold text-white">العربية</span>
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <a href={dictionaryChapterUrl} class="rounded-full border border-line bg-paper px-3 py-1.5 text-sm font-semibold text-accent hover:bg-accent-soft">
              Kamus Bab {lesson.chapter}, Buku {lesson.bookNumber}
            </a>
            <button
              type="button"
              class="durusul-article-read"
              data-article-read-toggle
              data-read-key={`durusul:${lesson.bookNumber}:${lesson.chapter}`}
              aria-pressed="false"
            >
              <span aria-hidden="true">✓</span>
              <span>أُنجزت القراءة</span>
            </button>
          </div>
        </div>
        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-muted">كتاب {lesson.bookNumber} · باب {lesson.chapter}</p>
        <h1 class="arabic mt-3 text-4xl font-semibold leading-tight text-accent sm:text-5xl" dir="rtl">{lesson.title}</h1>

        {lesson.toc.length > 0 && (
          <nav class="lesson-index lesson-index-ar mt-8" aria-label="فهرس الدرس">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.12em] text-muted">الفهرس</p>
              <h2 class="arabic mt-1 text-2xl font-semibold text-ink" dir="rtl">موضوعات الدرس</h2>
            </div>
            <ol>
              {lesson.toc.map((item) => (
                <li class={item.level === 3 ? "is-subtopic" : ""}>
                  <a href={`#${item.id}`}>{item.title}</a>
                </li>
              ))}
            </ol>
          </nav>
        )}

        <div class="lesson-prose lesson-prose-ar mt-8" set:html={lesson.html} />
      </article>
    </main>
    <a href="#top" class="back-to-top" aria-label="الرجوع إلى الأعلى">↑</a>
    <script>
      const readStorageKey = "tuwailib:durusul-read";
      const readButton = document.querySelector("[data-article-read-toggle]");

      function readProgress() {
        try {
          return new Set(JSON.parse(localStorage.getItem(readStorageKey) || "[]"));
        } catch {
          return new Set();
        }
      }

      function writeProgress(progress) {
        localStorage.setItem(readStorageKey, JSON.stringify(Array.from(progress)));
      }

      function applyReadState(progress) {
        const key = readButton?.getAttribute("data-read-key");
        const isRead = key ? progress.has(key) : false;
        readButton?.classList.toggle("is-read", isRead);
        readButton?.setAttribute("aria-pressed", String(isRead));
      }

      const progress = readProgress();
      applyReadState(progress);
      readButton?.addEventListener("click", () => {
        const key = readButton.getAttribute("data-read-key");
        if (!key) return;
        if (progress.has(key)) progress.delete(key);
        else progress.add(key);
        writeProgress(progress);
        applyReadState(progress);
      });
    </script>
  </body>
</html>
